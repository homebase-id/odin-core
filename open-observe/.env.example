# OpenObserve stack — the environment surface the compose files (compose.s3.yml, compose.local.yml)
# interpolate. Caddy runs separately.
# Ansible renders the REAL .env (mode 0600, on the log host) from the vault; this file documents every
# variable and is safe to commit. NO real secrets here — placeholders only. Keep secrets in ansible-vault.

# --- images (pin concrete versions; never :latest) ---
# repo: https://gallery.ecr.aws/zinclabs/openobserve
OPENOBSERVE_VERSION=v0.91.0         # pinned OSS (AGPL) GA, released 2026-06-22; bump deliberately
OO_INIT_IMAGE=curlimages/curl:8.21.0  # one-shot oo-init bootstrap container (waits for OO, creates ingest user)

# --- OpenObserve root (UI admin + used by oo-init to provision the ingest user) ---
OO_ROOT_USER_EMAIL=root@homebase.id
OO_ROOT_USER_PASSWORD=CHANGE_ME_IN_VAULT

# --- ingestion user (the oo-init container creates this dedicated, non-root user on bring-up) ---
# NOTE: OSS OpenObserve has NO lower-privilege role. Non-admin roles ("Custom roles not allowed") and
# scoped service accounts are enterprise RBAC only, so this user is an org ADMIN. The benefit is credential
# hygiene (root stays off the shippers; rotate/disable independently), NOT least privilege.
OO_INGEST_EMAIL=ingest@homebase.id  # dedicated ingest identity; shippers authenticate as THIS, not root
OO_INGEST_PASSWORD=CHANGE_ME_IN_VAULT
OO_INGEST_ROLE=admin                # OSS accepts only 'admin' for new users; anything else 400s "Custom roles not allowed"

# --- retention (time-based only; OpenObserve has no size-based retention) ---
OO_RETENTION_DAYS=30

# --- ingestion hostname: lives in the host's EXISTING Caddy (see README.md), NOT consumed here.
#     The shippers also point at it: OpenObserve__Endpoint=https://ingest.logs.<domain> ---

# --- data backend: Hetzner S3 (ZO_LOCAL_MODE stays UNSET = local/single-node; only data goes to S3) ---
ZO_S3_SERVER_URL=https://hel1.your-objectstorage.com   # Hetzner Helsinki endpoint; co-locate the log host here
ZO_S3_REGION_NAME=hel1
ZO_S3_BUCKET_NAME=raven-hosting-logs   # dedicated logs bucket; DNS-safe for virtual-hosted style
ZO_S3_ACCESS_KEY=CHANGE_ME_IN_VAULT
ZO_S3_SECRET_KEY=CHANGE_ME_IN_VAULT
ZO_S3_FORCE_PATH_STYLE=false         # Hetzner uses virtual-hosted style (bucket.<region>.your-objectstorage.com)
ZO_DISK_CACHE_MAX_SIZE=10240         # MB (verify unit on your version); bounds the local read-cache footprint

# --- memory bounds (single-node: pin caches so they don't each grab ~50% of RAM; sized for an ~8 GB host) ---
OO_MEM_LIMIT=6g                      # docker container memory ceiling; MUST exceed the cache sizes + overhead
OO_MEM_CACHE_MAX_SIZE=2048           # MB; ZO_MEMORY_CACHE_MAX_SIZE (query-result cache)
OO_DATAFUSION_CACHE_MAX_SIZE=2048    # MB; ZO_MEMORY_CACHE_DATAFUSION_MAX_SIZE (query engine; don't set too low)
OO_FILE_MOVE_THREAD_NUM=1            # ZO_FILE_MOVE_THREAD_NUM; compaction threads (default cores x2). 1 suits 2 vCPU

# --- operational / feature flags ---
OO_TELEMETRY=false                   # ZO_TELEMETRY; disable anonymous phone-home (self-hosted)
OO_PROMETHEUS_ENABLED=true           # ZO_PROMETHEUS_ENABLED; expose OO's own metrics on /metrics (off by default). Scrape for self-monitoring.
OO_INGEST_ALLOWED_UPTO=5             # ZO_INGEST_ALLOWED_UPTO (hours): events timestamped OLDER than this are SILENTLY DROPPED. Default 5.
                                     #   Raise if identity hosts backfill/replay after an outage, or if clocks skew. The future-side
                                     #   limit (ZO_INGEST_ALLOWED_IN_FUTURE, default 24h) is left at its default and not exposed here.
# Comma-separated field lists; empty = OpenObserve's built-in defaults only. VERIFY the exact field names your
# Serilog OTLP sink emits before setting these (the rendered message usually lands in the OTLP `body` field, which
# is NOT in the default full-text set of log,message,msg,content,data,json).
OO_INDEX_EXTRA_FIELDS=correlationid  # ZO_FEATURE_INDEX_EXTRA_FIELDS; secondary index for exact-match filters. Field names are OO-flattened+lowercased (Serilog CorrelationId -> correlationid). Applies to new data only; needs a container recreate.
OO_FULLTEXT_EXTRA_FIELDS=body        # ZO_FEATURE_FULLTEXT_EXTRA_FIELDS; extra match_all() fields beyond OO defaults. Applies to new data only; needs a container recreate.
OO_ALLOW_USER_DEFINED_SCHEMAS=true   # ZO_ALLOW_USER_DEFINED_SCHEMAS; enable UDS (field whitelist). INERT until you set the per-stream
                                     #   `defined_schema_fields`. Keep `store_original_data: true` so demoted fields land in the `_all`
                                     #   blob (retained + promotable) rather than dropped. Those two are PER-STREAM settings (stream
                                     #   settings API / UI / Terraform), NOT env vars.

# --- search / diagnostics (defaults = OpenObserve defaults; change only to debug) ---
OO_STREAMING_ENABLED=false           # ZO_STREAMING_ENABLED; DISABLED here: streaming search returned partial results + an internal h2 stream reset on v0.91.0 in this deployment. Off = full result set in one shot (streaming is a perf opt, not correctness). Re-test after an OO upgrade.
OO_GRPC_MAX_MESSAGE_SIZE=16          # ZO_GRPC_MAX_MESSAGE_SIZE (MB); internal gRPC message ceiling. Raise (e.g. 64) if broad queries reset the stream.
RUST_LOG=info                        # OO log level: error|warn|info|debug|trace. Bump to debug to trace search internals (noisy).
